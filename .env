# Copie ce fichier en ".env". NE JAMAIS partager ce fichier ni le commiter.

# --- Réseau ---
NETWORK=mainnet
WALLET_SEED=**********

# --- Trading ---
MAX_TRADE_XRP=10
MIN_PROFIT_PCT=0.5
SLIPPAGE_BUFFER_PCT=0.04
MIN_XRP_RESERVE_BUFFER=5

# IMPORTANT : d'abord true pour tester sans argent réel
DRY_RUN=false

SCAN_INTERVAL_MS=35000
MIN_SCAN_INTERVAL_MS=35000
LEDGER_TRIGGER_DEBOUNCE_MS=20000
BUSY_SCAN_LOG_THROTTLE_MS=30000

# --- Découverte tokens ---
DISCOVERY_MAX_TOKENS=50
DISCOVERY_LEDGERS_TO_SCAN=120
DISCOVERY_MIN_ACTIVITY=3
DISCOVERY_MIN_OFFERS=2
DISCOVERY_REQUIRE_BOTH_XRP_SIDES=true
DISCOVERY_REFRESH_MS=900000

# --- Scan carnets d'ordres ---
RATE_SCAN_ALL_PAIRS=true
RATE_SCAN_CONCURRENCY=2
MAX_ARBITRAGE_HOPS=4
MAX_CANDIDATE_CYCLES=80
ORDERBOOK_DEPTH_LIMIT=80

# --- Diagnostic order-book ---
ORDERBOOK_DIAGNOSTIC_SCAN=true
ORDERBOOK_RETURN_DIAGNOSTIC=true
ORDERBOOK_NEVER_EXECUTE_XRP_CYCLE=true

# --- Safe Rotation ---
SAFE_BUY_ONLY_WHEN_NO_TOKEN_BALANCE=false
SAFE_MIN_TOKEN_BALANCE=1
SAFE_EXIT_POSITIONS_FIRST=true
SAFE_ALLOW_XRP_TO_TOKEN_BUY=true

SAFE_SCAN_XRP_TO_TOKEN=true
SAFE_SCAN_TOKEN_TO_XRP=true
SAFE_PAYMENT_MAX_TARGETS=40
SAFE_PAYMENT_DEPTH_LIMIT=80

SAFE_ESTIMATED_FEE_XRP=0.0002
SAFE_MIN_NET_PROFIT_XRP=0.09
PATH_FIND_COOLDOWN_MS=300000

# --- Trustlines ---
SAFE_TRUSTLINE_TOKENS=524C555344000000000000000000000000000000.rMxCKbEDwqr76QuheSUMdEGf4B9xJ8m5De,USD.rvYAfWj5gh67oV6fW32ZzP3Aw4Eubs59B,EUR.rhub8VRN55s94qWKDv6jmDy1pUykJzF3wq
SAFE_TRUSTLINE_LIMIT=1000000000
SAFE_TRUSTLINE_DRY_RUN=true

# --- Risque ---
MAX_DAILY_LOSS_XRP=5
MAX_CONSECUTIVE_FAILURES=3
COOLDOWN_AFTER_BREAKER_MS=900000
CONFIRM_FIRST_N_TRADES=0

# --- Logs ---
LOG_LEVEL=INFO
DEBUG_TOKEN_DISCOVERY=false
DEBUG_TOKEN_LIMIT=80
DEBUG_LEDGER_LIMIT=10
DEBUG_RATE_SAMPLE=false
DEBUG_RATE_SAMPLE_LIMIT=30
DEBUG_CYCLE_REJECTIONS=true
DEBUG_CANDIDATE_LIMIT=20
DEBUG_BOOK_DEPTH=false

# --- Dashboard ---
DASHBOARD_ENABLED=true
DASHBOARD_PORT=4173
